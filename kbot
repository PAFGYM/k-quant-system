#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# kbot — K-Quant 봇 통합 관리 CLI v8.7
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 프로세스:
#   ./kbot start        봇 시작
#   ./kbot stop         봇 종료
#   ./kbot restart      봇 재시작
#   ./kbot status       상태 확인 (PID, 가동시간, 메모리)
#   ./kbot pid          PID만 출력
#
# 로그:
#   ./kbot logs [N]     최근 로그 N줄 (기본 50)
#   ./kbot errors [N]   ERROR/WARNING만 (기본 30)
#   ./kbot tail         실시간 로그 모니터링
#
# 정보:
#   ./kbot macro        매크로 스냅샷
#   ./kbot holdings     보유종목 목록
#   ./kbot balance      잔고 요약
#   ./kbot market       시장 현황
#   ./kbot health       워치독 1회 실행
#   ./kbot version      봇 버전
#
# 컨트롤:
#   ./kbot send "메시지"        텔레그램 메시지 전송
#   ./kbot ai "질문"            AI에게 질문
#   ./kbot scan [매니저]        매니저 매수 스캔 (scalp/swing/position/long_term)
#
# 소켓 컨트롤 (실행 중인 봇에 명령):
#   ./kbot jobs                 스케줄 작업 목록
#   ./kbot trigger <작업명>     작업 즉시 실행
#   ./kbot pause <작업명>       작업 일시중지
#   ./kbot resume <작업명>      작업 재개
#   ./kbot alert [모드]         경계모드 조회/변경
#   ./kbot scores              시스템 점수
#   ./kbot costs               API 비용

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

PID_FILE="$SCRIPT_DIR/bot.pid"
LOG_FILE="/tmp/kstock_bot.log"
VERSION="v8.7"

# ── 색상 ─────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── 헬퍼 ─────────────────────────────────

_get_pid() {
    pgrep -f "kstock.app" 2>/dev/null | head -1
}

_is_running() {
    [ -n "$(_get_pid)" ]
}

_print_header() {
    echo -e "${CYAN}${BOLD}K-Quant Bot ${VERSION}${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━"
}

_tg_py() {
    PYTHONPATH=src python3 "$SCRIPT_DIR/scripts/tg.py" "$@"
}

_ctrl() {
    # Send command to running bot via Unix socket
    local cmd="$1"
    shift
    local args="${1:-{}}"
    PYTHONPATH=src python3 -c "
import json, sys
from kstock.bot.control_client import send_command
r = send_command('$cmd', json.loads('$args'))
if not r.get('ok'):
    print(f'Error: {r.get(\"error\", \"unknown\")}', file=sys.stderr)
    sys.exit(1)
result = r.get('result', '')
if isinstance(result, str):
    print(result)
elif isinstance(result, list):
    for item in result:
        if isinstance(item, dict):
            icon = '▶' if item.get('enabled', True) else '⏸'
            print(f'  {icon} {item.get(\"name\", \"?\"):30s} next: {item.get(\"next_run\", \"-\")}')
        else:
            print(item)
elif isinstance(result, dict):
    for k, v in result.items():
        print(f'  {k}: {v}')
else:
    print(json.dumps(result, ensure_ascii=False, indent=2))
"
}

# ── 프로세스 관리 ─────────────────────────

cmd_start() {
    _print_header
    if _is_running; then
        local pid=$(_get_pid)
        echo -e "${YELLOW}이미 실행 중입니다 (PID: $pid)${NC}"
        return 0
    fi
    echo -e "봇 시작 중..."
    PYTHONPATH=src nohup python3 -c "from kstock.app import main; main()" > "$LOG_FILE" 2>&1 &
    local new_pid=$!
    echo "$new_pid" > "$PID_FILE"
    sleep 3
    if _is_running; then
        echo -e "${GREEN}봇 시작 완료 (PID: $new_pid)${NC}"
    else
        echo -e "${RED}봇 시작 실패. 로그 확인: ./kbot logs${NC}"
        return 1
    fi
}

cmd_stop() {
    _print_header
    local pid=$(_get_pid)
    if [ -z "$pid" ]; then
        echo -e "${YELLOW}봇이 실행 중이지 않습니다${NC}"
        rm -f "$PID_FILE"
        return 0
    fi
    echo -e "봇 종료 중 (PID: $pid)..."
    kill "$pid" 2>/dev/null || true
    for i in $(seq 1 5); do
        if ! _is_running; then
            break
        fi
        sleep 1
    done
    if _is_running; then
        echo -e "${YELLOW}강제 종료...${NC}"
        kill -9 "$pid" 2>/dev/null || true
        sleep 1
    fi
    rm -f "$PID_FILE"
    echo -e "${GREEN}봇 종료됨${NC}"
}

cmd_restart() {
    cmd_stop
    sleep 2
    cmd_start
}

cmd_status() {
    _print_header
    local pid=$(_get_pid)
    if [ -z "$pid" ]; then
        echo -e "${RED}상태: 중지됨${NC}"
        return 0
    fi
    local uptime
    uptime=$(ps -p "$pid" -o etime= 2>/dev/null | tr -d ' ')
    local mem_kb
    mem_kb=$(ps -p "$pid" -o rss= 2>/dev/null | tr -d ' ')
    local mem_mb=$((mem_kb / 1024))
    local proc_count
    proc_count=$(pgrep -f "kstock.app" 2>/dev/null | wc -l | tr -d ' ')

    echo -e "${GREEN}상태: 실행 중${NC}"
    echo -e "  PID:      $pid"
    echo -e "  가동시간: $uptime"
    echo -e "  메모리:   ${mem_mb}MB"
    echo -e "  프로세스: ${proc_count}개"
    echo -e "  버전:     $VERSION"
    echo -e "  로그:     $LOG_FILE"

    if [ -f "$LOG_FILE" ]; then
        local conflicts
        conflicts=$(tail -100 "$LOG_FILE" 2>/dev/null | grep -c "409 Conflict" || true)
        if [ "$conflicts" -gt 5 ]; then
            echo -e "  ${RED}409 충돌: ${conflicts}회 (최근 100줄)${NC}"
        fi
    fi
}

# ── 로그 ──────────────────────────────────

cmd_logs() {
    local lines=${1:-50}
    if [ ! -f "$LOG_FILE" ]; then
        echo "로그 파일 없음: $LOG_FILE"
        return 1
    fi
    tail -"$lines" "$LOG_FILE"
}

cmd_errors() {
    local lines=${1:-30}
    if [ ! -f "$LOG_FILE" ]; then
        echo "로그 파일 없음: $LOG_FILE"
        return 1
    fi
    grep -E "ERROR|WARNING|CRITICAL|Exception|Traceback" "$LOG_FILE" | tail -"$lines"
}

cmd_tail() {
    if [ ! -f "$LOG_FILE" ]; then
        echo "로그 파일 없음: $LOG_FILE"
        return 1
    fi
    echo -e "${CYAN}실시간 로그 (Ctrl+C로 종료)${NC}"
    tail -f "$LOG_FILE"
}

# ── 정보 ──────────────────────────────────

cmd_health() {
    _print_header
    echo "워치독 실행 중..."
    if [ -f "$SCRIPT_DIR/scripts/bot_watchdog.sh" ]; then
        bash "$SCRIPT_DIR/scripts/bot_watchdog.sh"
    else
        if _is_running; then
            local pid=$(_get_pid)
            local proc_count
            proc_count=$(pgrep -f "kstock.app" 2>/dev/null | wc -l | tr -d ' ')
            if [ "$proc_count" -gt 1 ]; then
                echo -e "${RED}중복 프로세스 감지: ${proc_count}개${NC}"
            else
                echo -e "${GREEN}정상 (PID: $pid)${NC}"
            fi
        else
            echo -e "${RED}봇이 실행 중이지 않습니다${NC}"
        fi
    fi
}

cmd_macro() {
    _tg_py --macro --no-send
}

cmd_holdings() {
    _tg_py --holdings --no-send
}

cmd_balance() {
    _tg_py --balance --no-send
}

cmd_market() {
    _tg_py --market --no-send
}

cmd_version() {
    echo "$VERSION"
}

cmd_pid() {
    local pid=$(_get_pid)
    if [ -n "$pid" ]; then
        echo "$pid"
    else
        echo "not running"
        return 1
    fi
}

# ── 컨트롤 ────────────────────────────────

cmd_send() {
    local msg="${1:-}"
    if [ -z "$msg" ]; then
        echo -e "${RED}사용법: ./kbot send \"메시지 내용\"${NC}"
        return 1
    fi
    _tg_py "$msg"
}

cmd_ai() {
    local question="${1:-}"
    if [ -z "$question" ]; then
        echo -e "${RED}사용법: ./kbot ai \"질문 내용\"${NC}"
        return 1
    fi
    _tg_py --ai "$question"
}

cmd_scan() {
    local mgr="${1:-all}"
    echo -e "${CYAN}매니저 스캔: $mgr${NC}"
    PYTHONPATH=src python3 -c "
import asyncio, sys
sys.path.insert(0, 'src')
from kstock.bot.investment_managers import MANAGERS, scan_manager_domain
from kstock.store.sqlite import SQLiteStore

async def run():
    db = SQLiteStore()
    mgr_key = '$mgr'
    if mgr_key == 'all':
        keys = list(MANAGERS.keys())
    elif mgr_key in MANAGERS:
        keys = [mgr_key]
    else:
        print(f'알 수 없는 매니저: {mgr_key}')
        print(f'사용 가능: {list(MANAGERS.keys())}')
        return
    for k in keys:
        mgr = MANAGERS[k]
        print(f'\\n{mgr[\"emoji\"]} {mgr[\"name\"]} 스캔 중...')
        result = await scan_manager_domain(k, db)
        if result:
            print(result[:2000])
        else:
            print('결과 없음')

asyncio.run(run())
"
}

# ── 소켓 컨트롤 (실행 중인 봇) ────────────

cmd_jobs() {
    _print_header
    echo -e "${BOLD}스케줄 작업 목록${NC}"
    echo ""
    _ctrl "list_jobs"
}

cmd_trigger() {
    local job_name="${1:-}"
    if [ -z "$job_name" ]; then
        echo -e "${RED}사용법: ./kbot trigger <작업명>${NC}"
        echo ""
        echo "주요 작업:"
        echo "  morning_briefing      모닝 브리핑"
        echo "  us_premarket_briefing 미국 프리마켓"
        echo "  daily_pdf_report      장마감 리포트"
        echo "  daily_self_report     자가진단"
        echo "  daily_system_score    시스템 점수"
        echo "  sentiment_analysis    뉴스 감성분석"
        echo "  premarket_buy_planner 매수 플래너"
        echo "  sector_rotation_check 섹터 로테이션"
        echo "  contrarian_scan       역발상 스캔"
        echo "  signal_evaluation     시그널 평가"
        echo "  auto_classify         자동 분류"
        return 1
    fi
    echo -e "${CYAN}작업 실행: $job_name${NC}"
    _ctrl "trigger_job" "{\"name\": \"$job_name\"}"
}

cmd_pause() {
    local job_name="${1:-}"
    if [ -z "$job_name" ]; then
        echo -e "${RED}사용법: ./kbot pause <작업명>${NC}"
        return 1
    fi
    _ctrl "pause_job" "{\"name\": \"$job_name\"}"
}

cmd_resume() {
    local job_name="${1:-}"
    if [ -z "$job_name" ]; then
        echo -e "${RED}사용법: ./kbot resume <작업명>${NC}"
        return 1
    fi
    _ctrl "resume_job" "{\"name\": \"$job_name\"}"
}

cmd_alert() {
    local mode="${1:-}"
    if [ -z "$mode" ]; then
        _ctrl "alert_mode"
    else
        _ctrl "alert_mode" "{\"mode\": \"$mode\"}"
    fi
}

cmd_scores() {
    _print_header
    echo -e "${BOLD}시스템 점수${NC}"
    echo ""
    _ctrl "get_score"
}

cmd_costs() {
    _print_header
    echo -e "${BOLD}API 비용${NC}"
    echo ""
    _ctrl "get_cost"
}

# ── Claude Code ────────────────────────────

cmd_claude() {
    local prompt="${1:-}"
    if [ -z "$prompt" ]; then
        echo -e "${RED}사용법: ./kbot claude \"프롬프트\"${NC}"
        echo ""
        echo "예시:"
        echo "  ./kbot claude \"봇 로그 확인해줘\""
        echo "  ./kbot claude \"테스트 실행해줘\""
        echo "  ./kbot claude \"삼성전자 분석해줘\""
        return 1
    fi

    # 봇이 실행 중이면 소켓 경유 (결과를 텔레그램에도 전송)
    if _is_running && [ -S "/tmp/kquant_control.sock" ]; then
        echo -e "${CYAN}Claude Code 실행 (봇 경유)...${NC}"
        # JSON escape the prompt
        local escaped_prompt
        escaped_prompt=$(python3 -c "import json; print(json.dumps('$prompt'))")
        _ctrl "run_claude" "{\"prompt\": $escaped_prompt}"
    else
        # 봇 미실행 시 직접 Claude CLI 실행
        echo -e "${CYAN}Claude Code 직접 실행...${NC}"
        local claude_cli=""
        for candidate in \
            "/Users/botddol/.local/bin/claude" \
            "/Users/botddol/.nvm/versions/node/v20.20.0/bin/claude" \
            "/opt/homebrew/bin/claude" \
            "/usr/local/bin/claude"; do
            if [ -f "$candidate" ]; then
                claude_cli="$candidate"
                break
            fi
        done
        if [ -z "$claude_cli" ]; then
            echo -e "${RED}Claude CLI를 찾을 수 없습니다${NC}"
            return 1
        fi
        PYTHONPATH=src "$claude_cli" -p "$prompt" \
            --output-format text \
            --dangerously-skip-permissions \
            --model sonnet \
            --max-turns 5
    fi
}

# ── 도움말 ────────────────────────────────

cmd_help() {
    _print_header
    echo ""
    echo "사용법: ./kbot <명령>"
    echo ""
    echo -e "  ${BOLD}프로세스 관리${NC}"
    echo "    start              봇 시작"
    echo "    stop               봇 종료"
    echo "    restart            봇 재시작"
    echo "    status             상태 확인"
    echo "    pid                PID만 출력"
    echo ""
    echo -e "  ${BOLD}로그${NC}"
    echo "    logs [N]           최근 로그 N줄 (기본 50)"
    echo "    errors [N]         ERROR/WARNING만 (기본 30)"
    echo "    tail               실시간 로그 모니터링"
    echo ""
    echo -e "  ${BOLD}정보${NC}"
    echo "    macro              매크로 스냅샷"
    echo "    holdings           보유종목 목록"
    echo "    balance            잔고 요약"
    echo "    market             시장 현황"
    echo "    health             워치독 실행"
    echo "    version            봇 버전"
    echo ""
    echo -e "  ${BOLD}컨트롤${NC}"
    echo "    send \"메시지\"       텔레그램 메시지 전송"
    echo "    ai \"질문\"          AI에게 질문"
    echo "    scan [매니저]       매수 스캔 (scalp/swing/position/long_term/all)"
    echo ""
    echo -e "  ${BOLD}Claude Code${NC}"
    echo "    claude \"프롬프트\"   Claude Code 실행 (봇 경유 or 직접)"
    echo ""
    echo -e "  ${BOLD}소켓 컨트롤 (실행 중인 봇)${NC}"
    echo "    jobs               스케줄 작업 목록"
    echo "    trigger <작업명>   작업 즉시 실행"
    echo "    pause <작업명>     작업 일시중지"
    echo "    resume <작업명>    작업 재개"
    echo "    alert [모드]       경계모드 조회/변경 (normal/elevated/wartime)"
    echo "    scores             시스템 점수"
    echo "    costs              API 비용"
    echo ""
}

# ── 메인 ─────────────────────────────────

case "${1:-help}" in
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    logs)     cmd_logs "${2:-50}" ;;
    errors)   cmd_errors "${2:-30}" ;;
    tail)     cmd_tail ;;
    health)   cmd_health ;;
    macro)    cmd_macro ;;
    holdings) cmd_holdings ;;
    balance)  cmd_balance ;;
    market)   cmd_market ;;
    version)  cmd_version ;;
    pid)      cmd_pid ;;
    send)     cmd_send "${2:-}" ;;
    ai)       cmd_ai "${2:-}" ;;
    scan)     cmd_scan "${2:-all}" ;;
    # Claude Code
    claude)   cmd_claude "${2:-}" ;;
    # 소켓 컨트롤
    jobs)     cmd_jobs ;;
    trigger)  cmd_trigger "${2:-}" ;;
    pause)    cmd_pause "${2:-}" ;;
    resume)   cmd_resume "${2:-}" ;;
    alert)    cmd_alert "${2:-}" ;;
    scores)   cmd_scores ;;
    costs)    cmd_costs ;;
    help|-h|--help) cmd_help ;;
    *)
        echo -e "${RED}알 수 없는 명령: $1${NC}"
        cmd_help
        exit 1
        ;;
esac
